type UserID string

type User {
  Id UserID
  Name string
}

type TestRequest {
  Message string
  Count int
  Many []string
  User User
  Users []User
}

type TestHeader {
  ID string
  SessionToken string
}

type TestResponse {
  User User
}

Server {
  POST url/to/use Test body(TestRequest) returns(TestResponse)
  GET url/to/get TestGet returns(TestResponse)
  PUT url/that/returns/nothing TestNothing
}