type UserID string

type User {
  ID UserID
  Name string
  Email string
}

type Session {
  UserID UserID
  Token string
}

type SignupBody {
  User User
  Password string
}

type SignupResponse {
  User User
}

type SignInBody {
  UserID UserID
  Password string
}

type SignInResponse {
  Session Session
}

type GetUserResponse {
  User User
}

Server {
  POST /user/new Signup body(SignupBody) returns(SignupResponse)
  POST /session/new SignIn body(SignInBody) returns(SignInResponse)
  GET /user/{UserID} GetUser returns(GetUserResponse)
}