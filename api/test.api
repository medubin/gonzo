type UserID string

type User {
  ID UserID
  Name string
  Email string
}

type Session {
  UserID UserID
  Token string
}

type SignupBody {
  User User
  Password string
}

type SignupResponse {
  User User
}

type SignInBody {
  UserID UserID
  Password string
}

type SignInResponse {
  Session Session
}

Server {
  POST user/new Signup body(SignupBody) returns(SignupResponse) setcookie(Session)
  POST session/new SignIn body(SignInBody) returns(SignInResponse) setcookie(Session)
}